datasource db {
  provider = "postgresql"
}


generator client {
  provider = "prisma-client"
  output   = "./generated"
}


model User {
  id        String  @id @default(uuid())  
  name      String  
  username  String  @unique  
  password  String  
  scores    Score[] 
  createdAt DateTime @default(now()) 
}

model Score {
  id     String   @id @default(uuid()) 
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  userId String
  value  Int      
  date   DateTime @default(now()) 
  }